#include "DeleteIsland.h"
#include <algorithm> // remove_if

void HandleDeleteIsland() {
    Vector2 mouse = GetMousePosition();

    if (IsMouseButtonPressed(MOUSE_LEFT_BUTTON)) {
        for (int i = 0; i < mapIslands.size(); i++) {

            // Kiểm tra click vào đảo
            if (CheckCollisionPointCircle(mouse, mapIslands[i].position, 20)) {

                int removedID = mapIslands[i].id;

                // 1. Xóa đảo
                mapIslands.erase(mapIslands.begin() + i);

                // 2. Xóa các cạnh liên quan
                mapEdges.erase(
                    remove_if(mapEdges.begin(), mapEdges.end(),
                        [removedID](Edge e) {
                            return e.u == removedID || e.v == removedID;
                        }),
                    mapEdges.end()
                );

                // 3. Cập nhật lại ID (tránh lệch)
                for (int j = 0; j < mapIslands.size(); j++) {
                    mapIslands[j].id = j;
                }

                break;
            }
        }
    }
}